clc;
clear;
close all;

%% ===== ДИАПАЗОН =====
x = linspace(0, pi, 100);
y = linspace(0, pi, 100);
[X, Y] = meshgrid(x, y);

%% ===== ФУНКЦИЯ =====
Z = cos(sin(Y)) .* sin(X);

%% ===== ГРАФИКИ =====
figure('Position',[100 100 1200 800]);

% --- 3D поверхность ---
subplot(2,2,1);
surf(X, Y, Z);
title('3D Surface: z = cos(sin(y))*sin(x)');
xlabel('x'); ylabel('y'); zlabel('z');
shading interp;
colorbar;

% --- Сетка ---
subplot(2,2,2);
mesh(X, Y, Z);
title('Mesh');

% --- Контур ---
subplot(2,2,3);
contourf(X, Y, Z, 20);
title('Contour');
colorbar;

% --- Heatmap ---
subplot(2,2,4);
imagesc(x, y, Z);
axis xy;
title('Heatmap');
colorbar;

sgtitle('Графіки функції z(x,y) = cos(sin(y)) * sin(x)');